# Server
PORT=5002
NODE_ENV=development

# Database — local dev (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Database — production (MySQL / Aiven). Switch prisma `provider` to `mysql` when using this.
# DATABASE_URL="mysql://USER:PASS@HOST:PORT/DB_NAME?sslaccept=strict"

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# CORS & cookies (comma-separated; no spaces after commas)
# Include 127.0.0.1 if you open the site that way (must match browser origin exactly).
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002
COOKIE_DOMAIN=
