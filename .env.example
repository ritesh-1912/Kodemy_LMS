# Database (SQLite for dev, MySQL/Postgres for production)
DATABASE_URL="file:./prisma/dev.db"

# Auth secrets (change in production)
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# CORS — browser calls from Vercel to this API (Render). Comma-separated, no spaces after commas.
# Any https://*.vercel.app is also allowed unless CORS_STRICT=true
# CORS_ORIGIN=https://kodemy-lms.vercel.app
# CORS_STRICT=true

# Cookie settings (for production cross-domain)
# COOKIE_DOMAIN=your-backend-domain.com
# REFRESH_COOKIE_NAME=refresh_token
